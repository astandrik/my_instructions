{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "risk_level", "summary", "evidence", "actions"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["pass", "fail", "needs_approval", "no_op", "blocked"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "actions": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
